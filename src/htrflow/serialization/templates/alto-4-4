<?xml version="1.0" encoding="UTF-8"?>
<alto xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.loc.gov/standards/alto/ns-v4#" xsi:schemaLocation="http://www.loc.gov/standards/alto/ns-v4# http://www.loc.gov/standards/alto/v4/alto-4-4.xsd">
    <Description>
        <MeasurementUnit>pixel</MeasurementUnit>
        <sourceImageInformation>
            <fileName>{{ document.image_name }}</fileName>
        </sourceImageInformation>
        <Processing ID="general">
            <processingDateTime>{{ metadata.created }}</processingDateTime>
            <processingSoftware>
                <softwareCreator>{{ metadata.creator }}</softwareCreator>
                <softwareName>{{ metadata.software_name }}</softwareName>
                <softwareVersion>{{ metadata.software_version }}</softwareVersion>
                <applicationDescription>{{ metadata.application_description }}</applicationDescription>
            </processingSoftware>
        </Processing>
        {%- for step in processing_steps %}
        <Processing ID="step{{ loop.index }}">
            <processingStepDescription>{{ step.description }}</processingStepDescription>
            <processingStepSettings>
                {%- for key, value in step.settings.items()|sort %}
                {{ key }}: {{ value }}
                {%- endfor %}
            </processingStepSettings>
        </Processing>
        {%- endfor %}
    </Description>
    {%- if document.regions %}
    <ReadingOrder>
        <OrderedGroup ID="ro">
        {%- for region in document.regions %}
            {%- set region_index = loop.index0 %}
            {%- if region.regions %}
            <OrderedGroup ID="ro_block{{ region_index }}">
            {%- for line in region.regions %}
                <ElementRef ID="ro_block{{ region_index }}_line{{ loop.index0 }}" REF="block{{ region_index }}_line{{ loop.index0 }}" />
            {%- endfor %}
            </OrderedGroup>
            {%- endif %}
        {%- endfor %}
        </OrderedGroup>
    </ReadingOrder>
    {%- endif %}
    <Layout>
        <Page WIDTH="{{ document.image.width }}" HEIGHT="{{ document.image.height }}" PHYSICAL_IMG_NR="0" ID="_{{ document.image_name }}">
            <PrintSpace>
                {%- for region in document.regions %}
                {%- if region.regions %}
                {%- set region_index = loop.index0 %}
                {%- set bbox = region.polygon.bbox %}
                {%- set hpos = bbox.xmin %}
                {%- set vpos = bbox.ymin %}
                <TextBlock ID="block_{{ region_index }}" HPOS="{{ hpos }}" VPOS="{{ vpos }}" HEIGHT="{{ bbox.height }}" WIDTH="{{ bbox.width  }}" CS="false">
                    {%- if region.polygon.points | length != 4 %}
                    <Shape>
                        <Polygon POINTS="{{ region.polygon.move((hpos, vpos)) }}"/>
                    </Shape>
                    {%- endif %}
                    {%- for line in region.regions %}
                    {%- set line_index = loop.index0 %}
                    {%- set bbox = line.polygon.bbox %}
                    <TextLine ID="block{{ region_index }}_line{{ line_index }}"  HPOS="{{ hpos + bbox.xmin }}" VPOS="{{ vpos + bbox.ymin }}" HEIGHT="{{ bbox.height }}" WIDTH="{{ bbox.width }}">
                        {%- if line.polygon.points | length != 4 %}
                        <Shape>
                            <Polygon POINTS="{{ line.polygon.move((hpos, vpos)) }}"/>
                        </Shape>
                        {%- endif %}
                        <String CONTENT="{{ (line.transcription[0].text if line.transcription else '') | e }}" />
                    </TextLine>
                    {%- endfor %}
                </TextBlock>
                {%- endif %}
                {%- endfor %}
            </PrintSpace>
        </Page>
    </Layout>
</alto>
